{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "capacitor:sync": "npx cap sync",
    "capacitor:build": "npm run build && npx cap sync",
    "ios:open": "npx cap open ios",
    "ios:build": "npx cap sync ios && xcodebuild -workspace ios/App/VanishText.xcworkspace -scheme VanishText -configuration Debug -destination 'platform=iOS Simulator,name=iPhone 15' build",
    "ios:device": "npx cap sync ios && xcodebuild -workspace ios/App/VanishText.xcworkspace -scheme VanishText -configuration Debug -device -destination 'generic platform=iOS' build",
    "android:open": "npx cap open android",
    "android:build": "npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
